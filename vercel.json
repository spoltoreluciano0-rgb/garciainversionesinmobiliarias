{
  "version": 2,
  "builds": [
    { "src": "server.js", "use": "@vercel/node" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "redirects": [
    { "source": "/index.html",            "destination": "/",                "permanent": true },
    { "source": "/propiedades.html",      "destination": "/propiedades",     "permanent": true },
    { "source": "/propiedad.html",        "destination": "/propiedad",       "permanent": true },
    { "source": "/gracias-consulta.html", "destination": "/gracias-consulta","permanent": true }
  ],
  "rewrites": [
    { "source": "/api/:path*",       "destination": "/server.js" },
    { "source": "/sitemap.xml",      "destination": "/server.js" },
    { "source": "/propiedades",      "destination": "/propiedades.html" },
    { "source": "/propiedad",        "destination": "/propiedad.html" },
    { "source": "/gracias-consulta", "destination": "/gracias-consulta.html" }
  ]
}
