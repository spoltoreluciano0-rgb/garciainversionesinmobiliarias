{
  "version": 2,
  "builds": [
    { "src": "server.js", "use": "@vercel/node" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)",              "dest": "server.js" },
    { "src": "/sitemap\\.xml",         "dest": "server.js" },
    { "src": "/index\\.html",          "dest": "server.js" },
    { "src": "/propiedades\\.html",    "dest": "server.js" },
    { "src": "/propiedad\\.html",      "dest": "server.js" },
    { "src": "/gracias-consulta\\.html","dest": "server.js" },
    { "src": "/propiedades",           "dest": "/public/propiedades.html" },
    { "src": "/propiedad",             "dest": "/public/propiedad.html" },
    { "src": "/gracias-consulta",      "dest": "/public/gracias-consulta.html" },
    { "src": "/propiedad/(.*)",        "dest": "server.js" },
    { "src": "/",                      "dest": "/public/index.html" },
    { "src": "/(.*)",                  "dest": "/public/$1" }
  ]
}
