# Copiar este archivo como .env en el servidor real
PORT=3000

# URL pública del sitio (sin barra final)
PUBLIC_BASE_URL=https://garciainversiones.com.ar

# CRM 2Clics
CRM_HASH=PEGAR_HASH_QUE_ENTREGA_2CLICS
CRM_AGENT_ID=123
CRM_MESSAGE_URL=https://api.2clics.com.ar/api/external/message

# Email (Resend)
# RESEND_API_KEY: obtenerla en resend.com → API Keys (NUNCA commitear este valor)
RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXXXXXX
# CONTACT_TO_EMAIL: email donde llegan las consultas (OBLIGATORIO para que funcionen los formularios)
CONTACT_TO_EMAIL=contacto@garciainversiones.com.ar
# CONTACT_FROM_EMAIL: debe usar un dominio verificado en Resend
CONTACT_FROM_EMAIL=García Inversiones <noreply@garciainversiones.com.ar>

# Medición / publicidad
GTM_CONTAINER_ID=GTM-XXXXXXX
GA4_MEASUREMENT_ID=G-XXXXXXXXXX
GOOGLE_ADS_CONVERSION_ID=AW-XXXXXXXXX
META_PIXEL_ID=000000000000000
META_ACCESS_TOKEN=PEGAR_TOKEN_DE_META_CAPI
META_TEST_EVENT_CODE=

# Cloudflare Turnstile (antispam CAPTCHA invisible)
# Obtener en: dash.cloudflare.com → Turnstile → Add Site
# NEXT_PUBLIC_TURNSTILE_SITE_KEY: clave pública (se expone al cliente — prefijo NEXT_PUBLIC_)
# TURNSTILE_SECRET_KEY: clave secreta (NUNCA commitear, solo server-side / Vercel env vars)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Supabase (service role — SOLO server-side, nunca exponer al frontend)
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=PEGAR_SERVICE_ROLE_KEY

# Feature flags
# PROPERTIES_ENABLED=true activa el listado público de propiedades (default: oculto "Selección en preparación")
PROPERTIES_ENABLED=false

# Sentry (monitoreo de errores) — SOLO server-side (Server Actions, webhook, middleware).
# El SDK de cliente se quitó por performance; NEXT_PUBLIC_SENTRY_DSN ya no se usa.
# Obtener el DSN en sentry.io → Project Settings → Client Keys. Vacío = inactivo (no-op).
SENTRY_DSN=
# Para subir source maps en el build (opcional pero recomendado): crear un Auth Token en Sentry
# SENTRY_ORG / SENTRY_PROJECT / SENTRY_AUTH_TOKEN (este último NUNCA commitear; solo en Vercel)
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
